VITE_NAKAMA_HOST=your-nakama-server.com

# Nakama HTTP port — 443 if you have SSL termination, 7350 otherwise
VITE_NAKAMA_PORT=7350

# true if your Nakama server has SSL/TLS (use wss:// and https://)
VITE_NAKAMA_USE_SSL=false

# Server key — must match --socket.server_key in your docker-compose
VITE_NAKAMA_KEY=defaultkey
